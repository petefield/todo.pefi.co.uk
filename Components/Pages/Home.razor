@page "/"
@rendermode InteractiveServer
@using TodoApp.Models
@using TodoApp.Services
@inject TodoService TodoService
@inject PushNotificationService PushNotificationService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>My Tasks</PageTitle>

<style>
    :root {
        --accent: #6366f1;
        --accent-hover: #4f46e5;
        --accent-light: #eef2ff;
        --surface: #ffffff;
        --surface-raised: #f8fafc;
        --border: #e2e8f0;
        --text-primary: #0f172a;
        --text-secondary: #64748b;
        --text-muted: #94a3b8;
        --status-done-bg: #f0fdf4;
        --status-done-border: #bbf7d0;
        --status-progress-bg: #fffbeb;
        --status-progress-border: #fde68a;
        --status-cancelled-bg: #f8fafc;
        --status-cancelled-border: #e2e8f0;
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -1px rgba(0,0,0,0.04);
        --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04);
    }

    * { box-sizing: border-box; }

    .todo-app {
        max-width: 720px;
        margin: 0 auto;
        padding: 1.25rem 1rem 6rem;
        font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", sans-serif;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        color: var(--text-primary);
    }

    /* ── Header ── */
    .todo-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 0 1.25rem;
    }
    .todo-header-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .todo-header-title h1 {
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0;
        color: var(--text-primary);
    }
    .header-badge {
        background: var(--accent);
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 99px;
        letter-spacing: 0.03em;
    }
    .btn-notify {
        background: var(--surface-raised);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        width: 40px;
        height: 40px;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, border-color 0.15s;
        color: var(--text-secondary);
        flex-shrink: 0;
    }
    .btn-notify:hover { background: var(--accent-light); border-color: var(--accent); }
    .btn-notify.active { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

    /* ── Hamburger menu ── */
    .header-menu {
        position: relative;
    }
    .btn-menu {
        background: var(--surface-raised);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        width: 40px;
        height: 40px;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, border-color 0.15s;
        color: var(--text-secondary);
        flex-shrink: 0;
    }
    .btn-menu:hover { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
    .btn-menu.open { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }
    .menu-dropdown {
        position: absolute;
        top: calc(100% + 0.4rem);
        right: 0;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        min-width: 210px;
        z-index: 300;
        overflow: hidden;
        animation: fadeIn 0.12s ease;
    }
    .menu-item {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
        font-family: inherit;
        background: none;
        border: none;
        color: var(--text-primary);
        cursor: pointer;
        text-align: left;
        transition: background 0.12s;
    }
    .menu-item:hover { background: var(--surface-raised); }
    .menu-item.active { color: var(--accent); font-weight: 600; }
    .menu-item-icon { font-size: 1rem; width: 1.2rem; text-align: center; flex-shrink: 0; }
    .menu-divider { height: 1px; background: var(--border); margin: 0.25rem 0; }

    /* ── Search ── */
    .todo-search {
        position: relative;
        margin-bottom: 0.85rem;
    }
    .todo-search-icon {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.9rem;
        pointer-events: none;
    }
    .todo-search input {
        width: 100%;
        font-size: 0.9rem;
        padding: 0.65rem 0.85rem 0.65rem 2.4rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        outline: none;
        background: var(--surface);
        color: var(--text-primary);
        font-family: inherit;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .todo-search input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    .todo-search input::placeholder { color: var(--text-muted); }

    /* ── Filters ── */
    .todo-filters {
        display: flex;
        gap: 0.35rem;
        margin-bottom: 1rem;
        overflow-x: auto;
        padding-bottom: 2px;
        scrollbar-width: none;
    }
    .todo-filters::-webkit-scrollbar { display: none; }
    .todo-filters button {
        flex-shrink: 0;
        padding: 0.4rem 0.9rem;
        font-size: 0.82rem;
        font-weight: 500;
        border: 1px solid var(--border);
        border-radius: 99px;
        background: var(--surface);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.15s;
        font-family: inherit;
        white-space: nowrap;
    }
    .todo-filters button:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
    .todo-filters button.active {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
        font-weight: 600;
    }

    /* ── List ── */
    .todo-list { display: flex; flex-direction: column; gap: 0.4rem; }

    .todo-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: box-shadow 0.15s;
    }
    .todo-item:hover { box-shadow: var(--shadow-md); }
    .todo-item.done { background: var(--status-done-bg); border-color: var(--status-done-border); }
    .todo-item.inprogress { background: var(--status-progress-bg); border-color: var(--status-progress-border); }
    .todo-item.cancelled { background: var(--status-cancelled-bg); border-color: var(--status-cancelled-border); }

    .todo-item-main {
        display: flex;
        align-items: center;
    }

    .drag-handle {
        display: flex;
        align-items: center;
        padding: 0 0.5rem 0 0.75rem;
        cursor: grab;
        color: var(--text-muted);
        font-size: 1rem;
        touch-action: none;
        align-self: stretch;
        opacity: 0.4;
        transition: opacity 0.15s;
    }
    .todo-item:hover .drag-handle { opacity: 1; }
    .drag-handle:active { cursor: grabbing; }

    .todo-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-right: 0.1rem;
    }
    .todo-item.pending .todo-status-dot { background: #94a3b8; }
    .todo-item.inprogress .todo-status-dot { background: #f59e0b; }
    .todo-item.done .todo-status-dot { background: #22c55e; }
    .todo-item.cancelled .todo-status-dot { background: #cbd5e1; }

    .todo-text {
        flex: 1;
        padding: 0.85rem 0.4rem 0.85rem 0.4rem;
        font-size: 0.95rem;
        color: var(--text-primary);
        word-break: break-word;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        cursor: pointer;
    }
    .todo-title-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .todo-title { line-height: 1.4; }
    .todo-notes-indicator {
        font-size: 0.7rem;
        color: var(--text-muted);
        background: var(--surface-raised);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.05rem 0.35rem;
        flex-shrink: 0;
        letter-spacing: 0.02em;
    }
    .todo-age {
        font-size: 0.72rem;
        color: var(--text-muted);
        font-weight: 400;
    }
    .todo-item.done .todo-title,
    .todo-item.cancelled .todo-title {
        text-decoration: line-through;
        color: var(--text-muted);
    }
    .todo-item.inprogress .todo-title { font-weight: 600; }

    /* ── Notes expand ── */
    .todo-notes-panel {
        border-top: 1px solid var(--border);
        padding: 0.75rem 0.75rem 0.75rem 2.5rem;
        background: rgba(0,0,0,0.015);
        user-select: text;
    }
    .todo-notes-textarea {
        width: 100%;
        font-size: 0.875rem;
        font-family: inherit;
        color: var(--text-primary);
        background: transparent;
        border: none;
        outline: none;
        resize: none;
        line-height: 1.6;
        min-height: 60px;
        padding: 0;
    }
    .todo-notes-textarea::placeholder { color: var(--text-muted); }
    .todo-notes-footer {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.5rem;
    }
    .btn-save-notes {
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.3rem 0.75rem;
        border: none;
        border-radius: var(--radius-sm);
        background: var(--accent);
        color: white;
        cursor: pointer;
        font-family: inherit;
        transition: background 0.15s, transform 0.15s;
    }
    .btn-save-notes:hover { background: var(--accent-hover); }
    .btn-save-notes.saved { background: #22c55e; transform: scale(1.05); cursor: default; }

    .todo-actions {
        display: flex;
        flex-shrink: 0;
        padding: 0 0.35rem;
        gap: 0.1rem;
    }
    .todo-actions button {
        border: none;
        background: none;
        font-size: 1rem;
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.12s, color 0.12s;
        color: var(--text-muted);
    }
    .btn-done { color: #22c55e; }
    .btn-inprogress { color: #f59e0b; }
    .btn-cancel { color: #f87171; }
    .btn-undo { color: var(--text-muted); }
    .todo-actions button:hover { background: var(--surface-raised); }
    .btn-done:hover { background: #f0fdf4 !important; color: #16a34a !important; }
    .btn-inprogress:hover { background: #fffbeb !important; color: #d97706 !important; }
    .btn-cancel:hover { background: #fef2f2 !important; color: #dc2626 !important; }

    /* ── Empty state ── */
    .todo-empty {
        text-align: center;
        padding: 4rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }
    .todo-empty-icon { font-size: 2.5rem; opacity: 0.3; }
    .todo-empty-text { color: var(--text-muted); font-size: 0.95rem; }

    /* ── Summary ── */
    .todo-summary {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 1.25rem 0.5rem 0;
        border-top: 1px solid var(--border);
        margin-top: 0.5rem;
    }
    .summary-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    .summary-dot { width: 6px; height: 6px; border-radius: 50%; }
    .summary-dot.pending { background: #94a3b8; }
    .summary-dot.inprogress { background: #f59e0b; }
    .summary-dot.done { background: #22c55e; }
    .summary-dot.cancelled { background: #cbd5e1; }
    .summary-count { font-weight: 600; color: var(--text-secondary); }

    /* ── Sortable ── */
    .sortable-ghost { opacity: 0.25; }
    .sortable-chosen { box-shadow: var(--shadow-lg) !important; transform: scale(1.015); }

    /* ── FAB ── */
    .btn-fab {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        height: 52px;
        padding: 0 1.5rem;
        border-radius: 99px;
        background: var(--accent);
        color: white;
        border: none;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        letter-spacing: 0.01em;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(99,102,241,0.45);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
        z-index: 100;
    }
    .btn-fab:hover {
        background: var(--accent-hover);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(99,102,241,0.55);
    }
    .btn-fab:active { transform: scale(0.97); }
    .btn-fab-icon { font-size: 1.2rem; line-height: 1; }

    /* ── Modal ── */
    .task-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,0.5);
        backdrop-filter: blur(4px);
        z-index: 200;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        animation: fadeIn 0.15s ease;
    }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .task-sheet {
        background: var(--surface);
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        padding: 1.5rem 1.25rem 2.5rem;
        width: 100%;
        max-width: 720px;
        box-shadow: 0 -8px 40px rgba(0,0,0,0.12);
        animation: slideUp 0.22s cubic-bezier(0.32, 0.72, 0, 1);
    }
    @@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

    .modal-handle {
        width: 36px;
        height: 4px;
        background: var(--border);
        border-radius: 99px;
        margin: 0 auto 1.25rem;
    }
    .modal-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.01em;
        margin-bottom: 1.1rem;
    }

    .modal-input {
        width: 100%;
        font-size: 1rem;
        padding: 0.8rem 1rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-md);
        outline: none;
        background: var(--surface-raised);
        color: var(--text-primary);
        font-family: inherit;
        transition: border-color 0.15s, box-shadow 0.15s;
        margin-bottom: 0.75rem;
    }
    .modal-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
        background: var(--surface);
    }
    .modal-input::placeholder { color: var(--text-muted); }

    /* ── Notes toggle in modal ── */
    .modal-notes-toggle {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: none;
        border: none;
        padding: 0.3rem 0;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-muted);
        cursor: pointer;
        font-family: inherit;
        margin-bottom: 0.75rem;
        transition: color 0.15s;
    }
    .modal-notes-toggle:hover { color: var(--accent); }
    .modal-notes-toggle.open { color: var(--accent); }

    .modal-notes-textarea {
        width: 100%;
        font-size: 0.9rem;
        font-family: inherit;
        color: var(--text-primary);
        background: var(--surface-raised);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-md);
        outline: none;
        resize: none;
        line-height: 1.6;
        padding: 0.75rem 1rem;
        min-height: 90px;
        transition: border-color 0.15s, box-shadow 0.15s;
        margin-bottom: 0.75rem;
    }
    .modal-notes-textarea:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
        background: var(--surface);
    }
    .modal-notes-textarea::placeholder { color: var(--text-muted); }

    .btn-modal-add {
        width: 100%;
        font-size: 1rem;
        font-weight: 600;
        padding: 0.9rem;
        border: none;
        border-radius: var(--radius-md);
        background: var(--accent);
        color: white;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        font-family: inherit;
        letter-spacing: 0.01em;
    }
    .btn-modal-add:hover { background: var(--accent-hover); }
    .btn-modal-add:active { transform: scale(0.98); }
    .btn-modal-add:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }

    /* ── Desktop ── */
    @@media (min-width: 768px) {
        .todo-app { padding: 2rem 1.5rem 6rem; }
        .todo-header { padding: 2rem 0 1.75rem; }
        .todo-header-title h1 { font-size: 2rem; }
        .btn-notify { width: 44px; height: 44px; font-size: 1.2rem; }
        .todo-search input { font-size: 0.95rem; padding: 0.75rem 1rem 0.75rem 2.5rem; }
        .todo-filters button { padding: 0.45rem 1.1rem; font-size: 0.875rem; }
        .todo-list { gap: 0.5rem; }
        .todo-item { border-radius: var(--radius-lg); }
        .drag-handle { padding: 0 0.6rem 0 1rem; }
        .todo-text { padding: 1rem 0.5rem 1rem 0.5rem; font-size: 1rem; }
        .todo-age { font-size: 0.78rem; }
        .todo-actions { padding: 0 0.5rem; gap: 0.15rem; }
        .todo-actions button { width: 40px; height: 40px; font-size: 1.05rem; }
        .btn-fab { bottom: 2.5rem; right: 2.5rem; }
        .task-overlay { align-items: center; padding: 1rem; }
        .task-sheet {
            border-radius: var(--radius-lg);
            padding: 2rem;
            max-width: 480px;
            animation: scaleIn 0.18s cubic-bezier(0.32, 0.72, 0, 1);
        }
        @@keyframes scaleIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .modal-handle { display: none; }
        .todo-notes-panel { padding-left: 3rem; }
    }
</style>

<div class="todo-app">
    <div class="todo-header">
        <div class="todo-header-title">
            <h1>My Tasks</h1>
            @if (items.Any())
            {
                <span class="header-badge">@items.Count(i => i.Status == TodoStatus.Pending || i.Status == TodoStatus.InProgress)</span>
            }
        </div>
        <div class="header-menu">
            <button class="btn-menu @(showMenu ? "open" : "")" @onclick="ToggleMenu" title="Menu">☰</button>
            @if (showMenu)
            {
                <div style="position:fixed;inset:0;z-index:299;" @onclick="() => showMenu = false"></div>
                <div class="menu-dropdown">
                    <button class="menu-item @(filters.Contains(TodoStatus.Cancelled) ? "active" : "")"
                            @onclick="ToggleCancelledFilter">
                        <span class="menu-item-icon">@(filters.Contains(TodoStatus.Cancelled) ? "✓" : " ")</span>
                        Show cancelled
                    </button>
                    @if (notificationState != "unsupported")
                    {
                        <div class="menu-divider"></div>
                        <button class="menu-item @(notificationState == "subscribed" ? "active" : "")"
                                @onclick="ToggleNotificationsFromMenu">
                            <span class="menu-item-icon">@(notificationState == "subscribed" ? "🔔" : "🔕")</span>
                            @(notificationState == "subscribed" ? "Disable reminders" : "Enable reminders")
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    @if (items.Any())
    {
        <div class="todo-search">
            <span class="todo-search-icon">🔍</span>
            <input @bind="searchQuery" @bind:event="oninput" placeholder="Search tasks…" inputmode="search" />
        </div>

        <div class="todo-filters">
            <button class="@(filters.Count == 0 ? "active" : "")" @onclick="ToggleAll">All</button>
            <button class="@(filters.Contains(TodoStatus.Pending) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.Pending)">Pending</button>
            <button class="@(filters.Contains(TodoStatus.InProgress) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.InProgress)">In Progress</button>
            <button class="@(filters.Contains(TodoStatus.Done) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.Done)">Done</button>
        </div>
    }

    @if (!FilteredItems.Any())
    {
        <div class="todo-empty">
            <div class="todo-empty-icon">✓</div>
            <div class="todo-empty-text">
                @if (!items.Any()) { <span>No tasks yet — tap + New Task to get started</span> }
                else { <span>Nothing matches your filters</span> }
            </div>
        </div>
    }
    else
    {
        <div @ref="listElement" class="todo-list">
            @foreach (var item in FilteredItems)
            {
                <div class="todo-item @item.Status.ToString().ToLower()" data-id="@item.Id">
                    <div class="todo-item-main">
                        <div class="drag-handle">⠿</div>
                        <div class="todo-status-dot"></div>

                        <div class="todo-text" @onclick="() => ToggleExpand(item.Id)">
                            <div class="todo-title-row">
                                <span class="todo-title">@item.Title</span>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <span class="todo-notes-indicator">notes</span>
                                }
                            </div>
                            <span class="todo-age">@FormatAge(item.CreatedAt)</span>
                        </div>

                        <div class="todo-actions">
                            @if (item.Status == TodoStatus.Pending)
                            {
                                <button class="btn-inprogress" @onclick="() => SetStatus(item.Id, TodoStatus.InProgress)" title="Start">▶</button>
                                <button class="btn-done" @onclick="() => SetStatus(item.Id, TodoStatus.Done)" title="Mark done">✓</button>
                                <button class="btn-cancel" @onclick="() => SetStatus(item.Id, TodoStatus.Cancelled)" title="Cancel">✕</button>
                            }
                            else if (item.Status == TodoStatus.InProgress)
                            {
                                <button class="btn-done" @onclick="() => SetStatus(item.Id, TodoStatus.Done)" title="Mark done">✓</button>
                                <button class="btn-undo" @onclick="() => SetStatus(item.Id, TodoStatus.Pending)" title="Back to pending">↩</button>
                            }
                            else
                            {
                                <button class="btn-undo" @onclick="() => SetStatus(item.Id, TodoStatus.Pending)" title="Reactivate">↩</button>
                            }
                        </div>
                    </div>

                    @if (expandedItems.Contains(item.Id))
                    {
                        <div class="todo-notes-panel">
                            <textarea class="todo-notes-textarea"
                                      placeholder="Add notes…"
                                      rows="3"
                                      value="@item.Description"
                                      @oninput="e => item.Description = e.Value?.ToString() ?? string.Empty"></textarea>
                            @{
                                var isDirty = (item.Description ?? string.Empty) != (savedDescriptions.GetValueOrDefault(item.Id) ?? string.Empty);
                                var saveLabel = savedItems.Contains(item.Id) ? "Saved" : "Save notes";
                                var savedClass = savedItems.Contains(item.Id) ? "saved" : "";
                            }
                            @if (isDirty || savedItems.Contains(item.Id))
                            {
                                <div class="todo-notes-footer">
                                    <button class="btn-save-notes @savedClass"
                                            @onclick="() => SaveNotes(item)">
                                        @saveLabel
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (items.Any())
    {
        <div class="todo-summary">
            <div class="summary-item">
                <span class="summary-dot pending"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.Pending)</span>
                <span>pending</span>
            </div>
            <div class="summary-item">
                <span class="summary-dot inprogress"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.InProgress)</span>
                <span>in progress</span>
            </div>
            <div class="summary-item">
                <span class="summary-dot done"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.Done)</span>
                <span>done</span>
            </div>
            <div class="summary-item">
                <span class="summary-dot cancelled"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.Cancelled)</span>
                <span>cancelled</span>
            </div>
        </div>
    }
</div>

<!-- FAB -->
<button class="btn-fab" @onclick="OpenModal">
    <span class="btn-fab-icon">＋</span>
    New Task
</button>

<!-- Modal -->
@if (showModal)
{
    <div class="task-overlay" @onclick="HandleBackdropClick">
        <div class="task-sheet" @onclick:stopPropagation="true">
            <div class="modal-handle"></div>
            <div class="modal-title">New Task</div>

            <input class="modal-input"
                   @bind="newTitle"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   placeholder="What needs to be done?"
                   inputmode="text"
                   @ref="modalInputRef" />

            <button class="modal-notes-toggle @(showModalNotes ? "open" : "")"
                    @onclick="() => showModalNotes = !showModalNotes">
                @(showModalNotes ? "▲" : "▼") &nbsp;@(showModalNotes ? "Hide notes" : "Add notes (optional)")
            </button>

            @if (showModalNotes)
            {
                <textarea class="modal-notes-textarea"
                          @bind="newDescription"
                          placeholder="Any extra details or notes…"
                          rows="3"></textarea>
            }

            <button class="btn-modal-add" @onclick="AddTodo" disabled="@string.IsNullOrWhiteSpace(newTitle)">
                Add Task
            </button>
        </div>
    </div>
}

@code {
    private List<TodoItem> items = [];
    private string newTitle = "";
    private string newDescription = "";
    private string searchQuery = "";
    private HashSet<TodoStatus> filters = new();
    private HashSet<Guid> expandedItems = new();
    private HashSet<Guid> savedItems = new();
    private Dictionary<Guid, string> savedDescriptions = new();
    private ElementReference listElement;
    private ElementReference modalInputRef;
    private DotNetObjectReference<Home>? dotNetRef;
    private string notificationState = "default";
    private bool showModal = false;
    private bool showModalNotes = false;
    private bool modalJustOpened = false;
    private bool showMenu = false;

    private IEnumerable<TodoItem> FilteredItems
    {
        get
        {
            IEnumerable<TodoItem> result;
            if (filters.Count == 0)
                result = items.Where(i => i.Status != TodoStatus.Cancelled);
            else
                result = items.Where(i => filters.Contains(i.Status));

            if (!string.IsNullOrWhiteSpace(searchQuery))
                result = result.Where(i => i.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        items = await TodoService.GetAllAsync();
        dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            notificationState = await JS.InvokeAsync<string>("getNotificationState");
            StateHasChanged();
        }
        if (FilteredItems.Any())
        {
            await JS.InvokeVoidAsync("initSortable", listElement, dotNetRef);
        }
        if (showModal)
        {
            try { await modalInputRef.FocusAsync(); } catch { }
        }
    }

    private void OpenModal()
    {
        newTitle = "";
        newDescription = "";
        showModalNotes = false;
        showModal = true;
        modalJustOpened = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void HandleBackdropClick()
    {
        if (modalJustOpened) { modalJustOpened = false; return; }
        CloseModal();
    }

    private async Task ToggleNotifications()
    {
        if (notificationState == "subscribed")
            await JS.InvokeVoidAsync("unsubscribeFromNotifications");
        else
        {
            var publicKey = PushNotificationService.GetPublicKey();
            await JS.InvokeAsync<bool>("subscribeToNotifications", publicKey);
        }
        notificationState = await JS.InvokeAsync<string>("getNotificationState");
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnReorder(string[] ids)
    {
        var guidList = ids.Select(Guid.Parse).ToList();
        await TodoService.ReorderAsync(guidList);
        items = await TodoService.GetAllAsync();
        StateHasChanged();
    }

    private async Task RefreshAsync() => items = await TodoService.GetAllAsync();

    private async Task AddTodo()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return;
        await TodoService.AddAsync(newTitle, newDescription);
        showModal = false;
        await RefreshAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !showModalNotes) await AddTodo();
        if (e.Key == "Escape") CloseModal();
    }

    private void ToggleMenu() => showMenu = !showMenu;

    private void ToggleCancelledFilter()
    {
        if (!filters.Remove(TodoStatus.Cancelled))
            filters.Add(TodoStatus.Cancelled);
        showMenu = false;
    }

    private async Task ToggleNotificationsFromMenu()
    {
        showMenu = false;
        await ToggleNotifications();
    }

    private void ToggleFilter(TodoStatus status)
    {
        if (!filters.Remove(status))
            filters.Add(status);
    }

    private void ToggleAll()
    {
        filters.Clear();
        showMenu = false;
    }

    private void ToggleExpand(Guid id)
    {
        if (expandedItems.Remove(id))
        {
            savedDescriptions.Remove(id);
        }
        else
        {
            expandedItems.Add(id);
            var item = items.FirstOrDefault(i => i.Id == id);
            if (item != null)
                savedDescriptions[id] = item.Description ?? string.Empty;
        }
    }

    private async Task SaveNotes(TodoItem item)
    {
        await TodoService.UpdateDescriptionAsync(item.Id, item.Description);
        savedDescriptions[item.Id] = item.Description ?? string.Empty;
        savedItems.Add(item.Id);
        StateHasChanged();
        await Task.Delay(2000);
        savedItems.Remove(item.Id);
        StateHasChanged();
    }

    private async Task SetStatus(Guid id, TodoStatus status)
    {
        await TodoService.SetStatusAsync(id, status);
        await RefreshAsync();
        if (status == TodoStatus.Done)
            await JS.InvokeVoidAsync("celebrate");
    }

    private static string FormatAge(DateTime createdAt)
    {
        var span = DateTime.UtcNow - createdAt;
        if (span.TotalMinutes >= 1 && span.TotalDays >= 1)
            return $"{(int)span.TotalDays}d {span.Hours:D2}:{span.Minutes:D2}";
        if (span.TotalMinutes >= 1)
            return $"{span.Hours:D2}:{span.Minutes:D2}";
        return "just now";
    }

    public async ValueTask DisposeAsync()
    {
        if (dotNetRef != null)
        {
            try { await JS.InvokeVoidAsync("destroySortable", listElement); } catch { }
            dotNetRef.Dispose();
        }
    }
}
