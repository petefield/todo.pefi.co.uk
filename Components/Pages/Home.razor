@page "/"
@rendermode InteractiveServer
@using TodoApp.Models
@using TodoApp.Services
@inject TodoService TodoService
@inject PushNotificationService PushNotificationService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>To Do's</PageTitle>

<style>
    :root {
        --accent: #6366f1;
        --accent-hover: #4f46e5;
        --accent-light: #eef2ff;
        --surface: #ffffff;
        --surface-raised: #f8fafc;
        --border: #e2e8f0;
        --text-primary: #0f172a;
        --text-secondary: #64748b;
        --text-muted: #94a3b8;
        --status-done-bg: #f0fdf4;
        --status-done-border: #bbf7d0;
        --status-done-text: #166534;
        --status-progress-bg: #fffbeb;
        --status-progress-border: #fde68a;
        --status-progress-text: #92400e;
        --status-cancelled-bg: #f8fafc;
        --status-cancelled-border: #e2e8f0;
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -1px rgba(0,0,0,0.04);
        --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04);
    }

    * { box-sizing: border-box; }

    .todo-app {
        max-width: 720px;
        margin: 0 auto;
        padding: 1.25rem 1rem 4rem;
        font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", sans-serif;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        color: var(--text-primary);
    }

    /* ── Header ── */
    .todo-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 0 1.25rem;
    }
    .todo-header-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .todo-header-title h1 {
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0;
        color: var(--text-primary);
    }
    .header-badge {
        background: var(--accent);
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.2rem 0.5rem;
        border-radius: 99px;
        letter-spacing: 0.03em;
    }
    .btn-notify {
        background: var(--surface-raised);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        width: 40px;
        height: 40px;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s, border-color 0.15s;
        color: var(--text-secondary);
        flex-shrink: 0;
    }
    .btn-notify:hover { background: var(--accent-light); border-color: var(--accent); }
    .btn-notify.active { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

    /* ── Input ── */
    .todo-input-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        padding: 0.5rem;
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
    }
    .todo-input-card input {
        flex: 1;
        font-size: 0.975rem;
        padding: 0.65rem 0.85rem;
        border: none;
        outline: none;
        background: transparent;
        color: var(--text-primary);
        font-family: inherit;
    }
    .todo-input-card input::placeholder { color: var(--text-muted); }
    .btn-add {
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.65rem 1.25rem;
        border: none;
        border-radius: var(--radius-md);
        background: var(--accent);
        color: white;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        white-space: nowrap;
        font-family: inherit;
        letter-spacing: 0.01em;
    }
    .btn-add:hover { background: var(--accent-hover); }
    .btn-add:active { transform: scale(0.97); }
    .btn-add:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }

    /* ── Search ── */
    .todo-search {
        position: relative;
        margin-bottom: 0.85rem;
    }
    .todo-search-icon {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 0.9rem;
        pointer-events: none;
    }
    .todo-search input {
        width: 100%;
        font-size: 0.9rem;
        padding: 0.65rem 0.85rem 0.65rem 2.4rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        outline: none;
        background: var(--surface);
        color: var(--text-primary);
        font-family: inherit;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .todo-search input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    .todo-search input::placeholder { color: var(--text-muted); }

    /* ── Filters ── */
    .todo-filters {
        display: flex;
        gap: 0.35rem;
        margin-bottom: 1rem;
        overflow-x: auto;
        padding-bottom: 2px;
        scrollbar-width: none;
    }
    .todo-filters::-webkit-scrollbar { display: none; }
    .todo-filters button {
        flex-shrink: 0;
        padding: 0.4rem 0.9rem;
        font-size: 0.82rem;
        font-weight: 500;
        border: 1px solid var(--border);
        border-radius: 99px;
        background: var(--surface);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.15s;
        font-family: inherit;
        white-space: nowrap;
    }
    .todo-filters button:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
    .todo-filters button.active {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
        font-weight: 600;
    }

    /* ── List ── */
    .todo-list { display: flex; flex-direction: column; gap: 0.4rem; }

    .todo-item {
        display: flex;
        align-items: center;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: box-shadow 0.15s, transform 0.15s;
    }
    .todo-item:hover { box-shadow: var(--shadow-md); }

    .todo-item.done {
        background: var(--status-done-bg);
        border-color: var(--status-done-border);
    }
    .todo-item.inprogress {
        background: var(--status-progress-bg);
        border-color: var(--status-progress-border);
    }
    .todo-item.cancelled {
        background: var(--status-cancelled-bg);
        border-color: var(--status-cancelled-border);
    }

    .drag-handle {
        display: flex;
        align-items: center;
        padding: 0 0.5rem 0 0.75rem;
        cursor: grab;
        color: var(--text-muted);
        font-size: 1rem;
        touch-action: none;
        align-self: stretch;
        opacity: 0.5;
        transition: opacity 0.15s;
    }
    .todo-item:hover .drag-handle { opacity: 1; }
    .drag-handle:active { cursor: grabbing; }

    .todo-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-right: 0.1rem;
    }
    .todo-item.pending .todo-status-dot { background: #94a3b8; }
    .todo-item.inprogress .todo-status-dot { background: #f59e0b; }
    .todo-item.done .todo-status-dot { background: #22c55e; }
    .todo-item.cancelled .todo-status-dot { background: #cbd5e1; }

    .todo-text {
        flex: 1;
        padding: 0.85rem 0.6rem 0.85rem 0.4rem;
        font-size: 0.95rem;
        color: var(--text-primary);
        word-break: break-word;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        min-width: 0;
    }
    .todo-title { line-height: 1.4; }
    .todo-age {
        font-size: 0.72rem;
        color: var(--text-muted);
        font-weight: 400;
    }
    .todo-item.done .todo-title,
    .todo-item.cancelled .todo-title {
        text-decoration: line-through;
        color: var(--text-muted);
    }
    .todo-item.inprogress .todo-title { font-weight: 600; }

    .todo-actions {
        display: flex;
        flex-shrink: 0;
        padding: 0 0.35rem;
        gap: 0.1rem;
    }
    .todo-actions button {
        border: none;
        background: none;
        font-size: 1rem;
        width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.12s, color 0.12s;
        color: var(--text-muted);
    }
    .btn-done { color: #22c55e; }
    .btn-inprogress { color: #f59e0b; }
    .btn-cancel { color: #f87171; }
    .btn-undo { color: var(--text-muted); }
    .todo-actions button:hover { background: var(--surface-raised); color: var(--text-primary); }
    .btn-done:hover { background: #f0fdf4 !important; color: #16a34a !important; }
    .btn-inprogress:hover { background: #fffbeb !important; color: #d97706 !important; }
    .btn-cancel:hover { background: #fef2f2 !important; color: #dc2626 !important; }

    /* ── Empty state ── */
    .todo-empty {
        text-align: center;
        padding: 4rem 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }
    .todo-empty-icon { font-size: 2.5rem; opacity: 0.3; }
    .todo-empty-text { color: var(--text-muted); font-size: 0.95rem; }

    /* ── Summary ── */
    .todo-summary {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 1.25rem 0.5rem 0;
        border-top: 1px solid var(--border);
        margin-top: 0.5rem;
    }
    .summary-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    .summary-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }
    .summary-dot.pending { background: #94a3b8; }
    .summary-dot.inprogress { background: #f59e0b; }
    .summary-dot.done { background: #22c55e; }
    .summary-dot.cancelled { background: #cbd5e1; }
    .summary-count { font-weight: 600; color: var(--text-secondary); }

    /* ── Sortable ── */
    .sortable-ghost { opacity: 0.25; }
    .sortable-chosen {
        box-shadow: var(--shadow-lg) !important;
        transform: scale(1.015);
    }

    /* ── Desktop ── */
    @@media (min-width: 768px) {
        .todo-app { padding: 2rem 1.5rem 4rem; }
        .todo-header { padding: 2rem 0 1.75rem; }
        .todo-header-title h1 { font-size: 2rem; }
        .btn-notify { width: 44px; height: 44px; font-size: 1.2rem; }
        .todo-input-card { padding: 0.6rem; }
        .todo-input-card input { font-size: 1.05rem; padding: 0.75rem 1rem; }
        .btn-add { font-size: 0.95rem; padding: 0.75rem 1.5rem; }
        .todo-search input { font-size: 0.95rem; padding: 0.75rem 1rem 0.75rem 2.5rem; }
        .todo-filters button { padding: 0.45rem 1.1rem; font-size: 0.875rem; }
        .todo-list { gap: 0.5rem; }
        .todo-item { border-radius: var(--radius-lg); }
        .drag-handle { padding: 0 0.6rem 0 1rem; }
        .todo-text { padding: 1rem 0.75rem 1rem 0.5rem; font-size: 1rem; }
        .todo-age { font-size: 0.78rem; }
        .todo-actions { padding: 0 0.5rem; gap: 0.15rem; }
        .todo-actions button { width: 40px; height: 40px; font-size: 1.05rem; }
    }
</style>

<div class="todo-app">
    <div class="todo-header">
        <div class="todo-header-title">
            <h1>My Tasks</h1>
            @if (items.Any())
            {
                <span class="header-badge">@items.Count(i => i.Status == TodoStatus.Pending || i.Status == TodoStatus.InProgress)</span>
            }
        </div>
        @if (notificationState != "unsupported")
        {
            <button class="btn-notify @(notificationState == "subscribed" ? "active" : "")"
                    title="@(notificationState == "subscribed" ? "Disable daily reminder" : "Enable daily reminder")"
                    @onclick="ToggleNotifications">
                @(notificationState == "subscribed" ? "🔔" : "🔕")
            </button>
        }
    </div>

    <div class="todo-input-card">
        <input @bind="newTitle" @bind:event="oninput" @onkeydown="HandleKeyDown"
               placeholder="Add a new task…" inputmode="text" />
        <button class="btn-add" @onclick="AddTodo" disabled="@string.IsNullOrWhiteSpace(newTitle)">Add</button>
    </div>

    @if (items.Any())
    {
        <div class="todo-search">
            <span class="todo-search-icon">🔍</span>
            <input @bind="searchQuery" @bind:event="oninput" placeholder="Search tasks…" inputmode="search" />
        </div>

        <div class="todo-filters">
            <button class="@(filters.Count == 0 ? "active" : "")" @onclick="ToggleAll">All</button>
            <button class="@(filters.Contains(TodoStatus.Pending) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.Pending)">Pending</button>
            <button class="@(filters.Contains(TodoStatus.InProgress) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.InProgress)">In Progress</button>
            <button class="@(filters.Contains(TodoStatus.Done) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.Done)">Done</button>
            <button class="@(filters.Contains(TodoStatus.Cancelled) ? "active" : "")" @onclick="() => ToggleFilter(TodoStatus.Cancelled)">Cancelled</button>
        </div>
    }

    @if (!FilteredItems.Any())
    {
        <div class="todo-empty">
            <div class="todo-empty-icon">✓</div>
            <div class="todo-empty-text">
                @if (!items.Any()) { <span>No tasks yet — add one above</span> }
                else { <span>Nothing matches your filters</span> }
            </div>
        </div>
    }
    else
    {
        <div @ref="listElement" class="todo-list">
            @foreach (var item in FilteredItems)
            {
                <div class="todo-item @item.Status.ToString().ToLower()" data-id="@item.Id">
                    <div class="drag-handle">⠿</div>
                    <div class="todo-status-dot"></div>

                    <div class="todo-text">
                        <span class="todo-title">@item.Title</span>
                        <span class="todo-age">@FormatAge(item.CreatedAt)</span>
                    </div>

                    <div class="todo-actions">
                        @if (item.Status == TodoStatus.Pending)
                        {
                            <button class="btn-inprogress" @onclick="() => SetStatus(item.Id, TodoStatus.InProgress)" title="Start">▶</button>
                            <button class="btn-done" @onclick="() => SetStatus(item.Id, TodoStatus.Done)" title="Mark done">✓</button>
                            <button class="btn-cancel" @onclick="() => SetStatus(item.Id, TodoStatus.Cancelled)" title="Cancel">✕</button>
                        }
                        else if (item.Status == TodoStatus.InProgress)
                        {
                            <button class="btn-done" @onclick="() => SetStatus(item.Id, TodoStatus.Done)" title="Mark done">✓</button>
                            <button class="btn-undo" @onclick="() => SetStatus(item.Id, TodoStatus.Pending)" title="Back to pending">↩</button>
                        }
                        else
                        {
                            <button class="btn-undo" @onclick="() => SetStatus(item.Id, TodoStatus.Pending)" title="Reactivate">↩</button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (items.Any())
    {
        <div class="todo-summary">
            <div class="summary-item">
                <span class="summary-dot pending"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.Pending)</span>
                <span>pending</span>
            </div>
            <div class="summary-item">
                <span class="summary-dot inprogress"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.InProgress)</span>
                <span>in progress</span>
            </div>
            <div class="summary-item">
                <span class="summary-dot done"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.Done)</span>
                <span>done</span>
            </div>
            <div class="summary-item">
                <span class="summary-dot cancelled"></span>
                <span class="summary-count">@items.Count(i => i.Status == TodoStatus.Cancelled)</span>
                <span>cancelled</span>
            </div>
        </div>
    }
</div>

@code {
    private List<TodoItem> items = [];
    private string newTitle = "";
    private string searchQuery = "";
    private HashSet<TodoStatus> filters = new();
    private ElementReference listElement;
    private DotNetObjectReference<Home>? dotNetRef;
    private string notificationState = "default";

    private IEnumerable<TodoItem> FilteredItems
    {
        get
        {
            IEnumerable<TodoItem> result;
            if (filters.Count == 0)
                result = items.Where(i => i.Status != TodoStatus.Cancelled);
            else
                result = items.Where(i => filters.Contains(i.Status));

            if (!string.IsNullOrWhiteSpace(searchQuery))
                result = result.Where(i => i.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        items = await TodoService.GetAllAsync();
        dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            notificationState = await JS.InvokeAsync<string>("getNotificationState");
            StateHasChanged();
        }
        if (FilteredItems.Any())
        {
            await JS.InvokeVoidAsync("initSortable", listElement, dotNetRef);
        }
    }

    private async Task ToggleNotifications()
    {
        if (notificationState == "subscribed")
        {
            await JS.InvokeVoidAsync("unsubscribeFromNotifications");
        }
        else
        {
            var publicKey = PushNotificationService.GetPublicKey();
            await JS.InvokeAsync<bool>("subscribeToNotifications", publicKey);
        }
        notificationState = await JS.InvokeAsync<string>("getNotificationState");
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnReorder(string[] ids)
    {
        var guidList = ids.Select(Guid.Parse).ToList();
        await TodoService.ReorderAsync(guidList);
        items = await TodoService.GetAllAsync();
        StateHasChanged();
    }

    private async Task RefreshAsync() => items = await TodoService.GetAllAsync();

    private async Task AddTodo()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return;
        await TodoService.AddAsync(newTitle);
        newTitle = "";
        await RefreshAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddTodo();
    }

    private void ToggleFilter(TodoStatus status)
    {
        if (!filters.Remove(status))
            filters.Add(status);
    }

    private void ToggleAll() => filters.Clear();

    private async Task SetStatus(Guid id, TodoStatus status)
    {
        await TodoService.SetStatusAsync(id, status);
        await RefreshAsync();
        if (status == TodoStatus.Done)
        {
            await JS.InvokeVoidAsync("celebrate");
        }
    }

    private static string FormatAge(DateTime createdAt)
    {
        var span = DateTime.UtcNow - createdAt;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalDays >= 1)
            return $"{(int)span.TotalDays}d {span.Hours:D2}:{span.Minutes:D2}";
        return $"{span.Hours:D2}:{span.Minutes:D2}";
    }

    public async ValueTask DisposeAsync()
    {
        if (dotNetRef != null)
        {
            try { await JS.InvokeVoidAsync("destroySortable", listElement); } catch { }
            dotNetRef.Dispose();
        }
    }
}
